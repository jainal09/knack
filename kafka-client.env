# Kafka client configuration
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=bench
KAFKA_LATENCY_TOPIC=bench-latency

# Workload parameters
TEST_DURATION_SEC=600
PAYLOAD_BYTES=1024
NUM_PRODUCERS=4
PEAK_RATE=10000
LATENCY_DURATION_SEC=300

# Consumer benchmark
NUM_CONSUMERS=4
KAFKA_CONSUMER_TOPIC=bench-consumer

# Producer+Consumer simultaneous benchmark
KAFKA_PRODCON_TOPIC=bench-prodcon

# Hardware profile
BENCH_CPUS=2.0
BENCH_MEMORY=4g
BENCH_DISK_TYPE=ssd
