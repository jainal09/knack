#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# knack — Kafka + NATS Benchmark Suite CLI
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

KNACK_VERSION="0.1.0"
# Resolve symlinks to find the real script location
_self="$0"
while [[ -L "$_self" ]]; do
  _dir="$(cd "$(dirname "$_self")" && pwd)"
  _self="$(readlink "$_self")"
  [[ "$_self" != /* ]] && _self="$_dir/$_self"
done
KNACK_ROOT="$(cd "$(dirname "$_self")" && pwd)"

# ─── Colors ──────────────────────────────────────────────────────────────────
_RST='\033[0m'; _BOLD='\033[1m'; _DIM='\033[2m'
_CYAN='\033[36m'; _MAG='\033[35m'; _YELLOW='\033[33m'; _GREEN='\033[32m'

# ─── Banner ──────────────────────────────────────────────────────────────────
banner() {
  printf "${_MAG}"
  cat <<'EOF'
  _  __                 _
 | |/ /_ __   __ _  ___| | __
 | ' /| '_ \ / _` |/ __| |/ /
 | . \| | | | (_| | (__|   <
 |_|\_\_| |_|\__,_|\___|_|\_\
EOF
  printf "${_RST}"
  printf "${_DIM}  Kafka + NATS Benchmark Suite v%s${_RST}\n\n" "$KNACK_VERSION"
}

# ─── Usage ───────────────────────────────────────────────────────────────────
usage() {
  banner
  printf "${_BOLD}USAGE${_RST}
  knack <command> [options]

${_BOLD}COMMANDS${_RST}
  ${_CYAN}run${_RST}                  Run the full benchmark suite
      --quick             Quick smoke test (~45 min)
      --scenario NAME     Run a single scenario (large|medium|small)
      --list              List available scenarios
      --duration SEC      Throughput test duration per run
      --reps N            Number of throughput repetitions
      --producers N       Number of parallel producers
      --resume            Resume from last checkpoint
      --rerun STEPS       Re-run specific steps (comma-separated)

  ${_CYAN}status${_RST}               Show benchmark status
      --watch, -w [SEC]   Live watch mode (default: 5s refresh)
      --all               All past runs
      --latest N          Last N runs

  ${_CYAN}report${_RST}               Generate Markdown benchmark report
      --scenario NAME(s)  Specific scenario(s)

  ${_CYAN}infra${_RST}                Manage broker infrastructure
      up                  Start Kafka + NATS containers
      down                Stop and remove containers + volumes
      up --ui             Start with UI tools (Redpanda Console, Nui)

  ${_CYAN}clean${_RST}                Remove previous benchmark results
      --scenario NAME     Clean only a specific scenario (large|medium|small)
      --dry-run           Show what would be deleted without removing
      --force, -f         Skip confirmation prompt

  ${_CYAN}self-update${_RST}          Pull the latest version from GitHub

  ${_CYAN}version${_RST}              Print version
  ${_CYAN}help${_RST}                 Show this help message

${_BOLD}EXAMPLES${_RST}
  knack infra up              # Start brokers
  knack run --quick           # Quick smoke test
  knack status --watch        # Monitor progress
  knack report                # Generate reports
  knack clean                 # Remove all previous results
  knack clean --scenario large # Remove only 'large' scenario results
  knack clean --dry-run       # Preview what would be deleted
  knack self-update           # Update Knack to the latest version
  knack infra down            # Tear down
"
}

# ─── Commands ────────────────────────────────────────────────────────────────

cmd_run() {
  banner
  exec "$KNACK_ROOT/run_scenarios.sh" "$@"
}

cmd_status() {
  exec "$KNACK_ROOT/bench_status.sh" "$@"
}

cmd_report() {
  exec "$KNACK_ROOT/bench_report.sh" "$@"
}

cmd_clean() {
  local results_dir="$KNACK_ROOT/results"
  local scenario=""
  local dry_run=0
  local force=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --scenario)  scenario="$2"; shift 2 ;;
      --dry-run)   dry_run=1; shift ;;
      --force|-f)  force=1; shift ;;
      *) printf "${_YELLOW}Unknown option: %s${_RST}\n" "$1"; exit 1 ;;
    esac
  done

  # Determine target directory
  local target="$results_dir"
  if [[ -n "$scenario" ]]; then
    target="$results_dir/$scenario"
    if [[ ! -d "$target" ]]; then
      printf "${_YELLOW}No results found for scenario '%s' (looked in %s)${_RST}\n" "$scenario" "$target"
      exit 0
    fi
  fi

  if [[ ! -d "$results_dir" ]]; then
    printf "${_GREEN}Nothing to clean — no results directory found.${_RST}\n"
    exit 0
  fi

  banner

  # Collect what would be deleted
  local items=()
  if [[ -n "$scenario" ]]; then
    items=("$target")
  else
    # Everything inside results/
    for f in "$results_dir"/*; do
      [[ -e "$f" ]] && items+=("$f")
    done
  fi

  if [[ ${#items[@]} -eq 0 ]]; then
    printf "${_GREEN}Nothing to clean.${_RST}\n"
    exit 0
  fi

  printf "${_CYAN}The following will be removed:${_RST}\n"
  local total_size
  total_size=$(du -sh "$target" 2>/dev/null | cut -f1 || echo "?")
  for f in "${items[@]}"; do
    if [[ -d "$f" ]]; then
      local count
      count=$(find "$f" -type f 2>/dev/null | wc -l | tr -d ' ')
      printf "  ${_DIM}📁 %s (%s files)${_RST}\n" "$(basename "$f")" "$count"
    else
      printf "  ${_DIM}📄 %s${_RST}\n" "$(basename "$f")"
    fi
  done
  printf "\n  ${_BOLD}Total size: %s${_RST}\n\n" "$total_size"

  if [[ $dry_run -eq 1 ]]; then
    printf "${_YELLOW}Dry run — nothing was deleted.${_RST}\n"
    exit 0
  fi

  if [[ $force -eq 0 ]]; then
    printf "${_YELLOW}Remove these results? [y/N] ${_RST}"
    local answer=""
    read -r answer
    case "$answer" in
      [yY]|[yY][eE][sS]) ;;
      *)
        printf "${_GREEN}Cancelled.${_RST}\n"
        exit 0
        ;;
    esac
  fi

  # Perform deletion
  if [[ -n "$scenario" ]]; then
    rm -rf "$target"
    printf "${_GREEN}✔ Removed results for scenario '%s'${_RST}\n" "$scenario"
  else
    rm -rf "$results_dir"
    printf "${_GREEN}✔ All benchmark results removed.${_RST}\n"
  fi
}

cmd_infra() {
  local action="${1:-}"
  shift || true

  local compose_kafka="$KNACK_ROOT/infra/docker-compose.kafka.yml"
  local compose_nats="$KNACK_ROOT/infra/docker-compose.nats.yml"

  case "$action" in
    up)
      local profile_args=()
      for arg in "$@"; do
        if [[ "$arg" == "--ui" ]]; then
          profile_args+=(--profile tools)
        fi
      done
      banner
      printf "${_GREEN}Starting Kafka + NATS infrastructure...${_RST}\n"
      docker compose -f "$compose_kafka" -f "$compose_nats" "${profile_args[@]}" up -d
      printf "\n${_GREEN}Infrastructure is up.${_RST}\n"
      printf "  Kafka  → localhost:9092\n"
      printf "  NATS   → localhost:4222\n"
      if [[ " ${profile_args[*]:-} " == *" tools "* ]]; then
        printf "  Redpanda Console → localhost:9080\n"
        printf "  Nui              → localhost:31311\n"
      fi
      ;;
    down)
      banner
      printf "${_YELLOW}Stopping and removing infrastructure...${_RST}\n"
      docker compose -f "$compose_kafka" -f "$compose_nats" --profile tools down -v
      printf "${_GREEN}Infrastructure removed.${_RST}\n"
      ;;
    *)
      printf "${_YELLOW}Usage: knack infra {up|down} [--ui]${_RST}\n"
      exit 1
      ;;
  esac
}

cmd_self_update() {
  banner
  printf "${_CYAN}Updating Knack...${_RST}\n\n"

  local before after
  before=$(git -C "$KNACK_ROOT" rev-parse --short HEAD 2>/dev/null || echo "unknown")

  if ! git -C "$KNACK_ROOT" pull --ff-only 2>&1; then
    printf "\n${_YELLOW}Fast-forward pull failed. Trying rebase...${_RST}\n"
    if ! git -C "$KNACK_ROOT" pull --rebase 2>&1; then
      printf "\n${_YELLOW}Pull failed. You may have local changes. Try:\n  cd %s && git stash && git pull && git stash pop${_RST}\n" "$KNACK_ROOT"
      exit 1
    fi
  fi

  after=$(git -C "$KNACK_ROOT" rev-parse --short HEAD 2>/dev/null || echo "unknown")

  echo ""
  if [[ "$before" == "$after" ]]; then
    printf "${_GREEN}✔ Already up to date (%s)${_RST}\n" "$after"
  else
    printf "${_GREEN}✔ Updated: %s → %s${_RST}\n" "$before" "$after"
    echo ""
    printf "${_DIM}Recent changes:${_RST}\n"
    git -C "$KNACK_ROOT" log --oneline "${before}..${after}" 2>/dev/null | head -10
  fi
}

cmd_version() {
  printf "knack %s\n" "$KNACK_VERSION"
}

# ─── Main dispatch ───────────────────────────────────────────────────────────
main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    run)         cmd_run "$@" ;;
    status)      cmd_status "$@" ;;
    report)      cmd_report "$@" ;;
    clean)       cmd_clean "$@" ;;
    infra)       cmd_infra "$@" ;;
    self-update) cmd_self_update ;;
    version)     cmd_version ;;
    help|-h|--help) usage ;;
    *)
      printf "${_YELLOW}Unknown command: %s${_RST}\n\n" "$cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"
