# NATS client configuration
NATS_URL=nats://localhost:4222
NATS_STREAM=BENCH
NATS_SUBJECT=bench.data
NATS_LATENCY_STREAM=BENCH_LATENCY
NATS_LATENCY_SUBJECT=bench.latency

# Workload parameters
TEST_DURATION_SEC=600
PAYLOAD_BYTES=1024
NUM_PRODUCERS=4
PEAK_RATE=10000
LATENCY_DURATION_SEC=300

# Hardware profile
BENCH_CPUS=2.0
BENCH_MEMORY=4g
BENCH_DISK_TYPE=ssd
